---
import { site } from '../data/site';

const stats = [
  { label: 'JVM tuning', value: '180→20ms', sub: 'GC pause cut' },
  { label: 'Throughput', value: '4×', sub: 'virtual threads vs pool' },
  { label: 'Routing time', value: '8→2min', sub: 'AI document agent' },
  { label: 'Lighthouse', value: '72→94', sub: 'frontend perf' },
];
---

<section
  id="top"
  class="relative overflow-hidden pt-20 pb-24 md:pt-28 md:pb-32"
>
  <div class="container-x relative">
    <div class="grid items-center gap-12 lg:grid-cols-[1.4fr_1fr]">
      <!-- Text column -->
      <div>
        <div class="mb-6 flex items-center gap-3 reveal">
          <span class="relative flex h-2.5 w-2.5">
            <span
              class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"
            ></span>
            <span
              class="relative inline-flex h-2.5 w-2.5 rounded-full bg-emerald-400"
            ></span>
          </span>
          <span class="text-xs uppercase tracking-[0.25em] text-muted"
            >Available for new opportunities</span
          >
        </div>

        <h1
          class="h-display text-5xl leading-[1.05] sm:text-6xl md:text-7xl lg:text-[80px] reveal"
        >
          Hi, I'm <span class="gradient-text">{site.shortName}</span>.<br />
          I build <span class="text-text">backend systems</span>
          <br class="hidden md:block" />that scale.
        </h1>

        <p
          class="mt-8 max-w-2xl text-lg leading-relaxed text-text/70 reveal"
          style="transition-delay: 120ms;"
        >
          {site.summary}
        </p>

        <div
          class="mt-10 flex flex-wrap items-center gap-3 reveal"
          style="transition-delay: 220ms;"
        >
          <a href="#projects" class="btn-primary">
            View my work
            <svg
              class="h-4 w-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
            >
              <path d="M5 12h14"></path>
              <path d="m12 5 7 7-7 7"></path>
            </svg>
          </a>
          <a href="#contact" class="btn-ghost">Get in touch</a>
          <a
            href={site.github}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-ghost"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"
              ><path
                d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1.1-.7.1-.7.1-.7 1.2.1 1.9 1.3 1.9 1.3 1.1 1.9 2.9 1.4 3.6 1 .1-.8.4-1.4.8-1.7-2.7-.3-5.5-1.3-5.5-6 0-1.3.5-2.4 1.3-3.2-.1-.3-.6-1.6.1-3.3 0 0 1-.3 3.4 1.2a11.7 11.7 0 0 1 6.2 0c2.4-1.5 3.4-1.2 3.4-1.2.7 1.7.2 3 .1 3.3.8.8 1.3 1.9 1.3 3.2 0 4.7-2.8 5.7-5.5 6 .4.4.8 1.1.8 2.2v3.2c0 .3.2.7.8.6A12 12 0 0 0 12 .3"
              ></path></svg
            >
            GitHub
          </a>
        </div>
      </div>

      <!-- Image column -->
      <div
        class="relative mx-auto aspect-[4/5] w-full max-w-md reveal lg:max-w-none"
        style="transition-delay: 320ms;"
      >
        <div
          class="absolute -inset-4 rounded-[2rem] bg-gradient-to-br from-accent/30 via-accent2/20 to-transparent blur-2xl"
        >
        </div>
        <div
          class="relative h-full w-full overflow-hidden rounded-[2rem] border border-border bg-surface"
        >
          <img
            src={site.profileImage}
            alt={`${site.name} — portrait`}
            class="h-full w-full object-cover"
          />
          <div
            class="pointer-events-none absolute inset-0 bg-gradient-to-t from-bg/40 via-transparent to-transparent"
          >
          </div>
        </div>
        <!-- floating tag -->
        <div
          class="absolute bottom-4 left-4 right-4 flex items-center gap-3 rounded-2xl border border-border bg-bg/80 px-4 py-3 backdrop-blur-md"
        >
          <span class="grid h-9 w-9 place-items-center rounded-xl bg-gradient-to-br from-accent to-accent2 text-black">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M5 12.55a11 11 0 0 1 14.08 0M1.42 9a16 16 0 0 1 21.16 0M8.53 16.11a6 6 0 0 1 6.95 0M12 20h.01"></path></svg>
          </span>
          <div class="leading-tight">
            <div class="font-display text-sm font-semibold text-text">
              {site.title}
            </div>
            <div class="text-xs text-muted">{site.location}</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Stats below -->
    <div
      class="mt-16 grid grid-cols-2 gap-6 sm:grid-cols-4 reveal"
      style="transition-delay: 420ms;"
    >
      {
        stats.map((s) => (
          <div class="rounded-xl border border-border bg-surface/40 p-4 backdrop-blur">
            <div class="font-display text-2xl font-semibold text-text">
              {s.value}
            </div>
            <div class="mt-1 text-xs uppercase tracking-wider text-muted">
              {s.label}
            </div>
            <div class="mt-1 text-xs text-text/50">{s.sub}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>
