---
import { projects } from '../data/site';
---

<section id="projects" class="section">
  <div class="container-x">
    <div class="flex flex-wrap items-end justify-between gap-6 reveal">
      <div class="max-w-2xl">
        <span class="heading-eyebrow">Selected Work</span>
        <h2 class="h-display mt-4 text-4xl md:text-5xl">Projects I've built.</h2>
        <p class="mt-4 text-text/70">
          A mix of production work, independent benchmarks, and undergrad
          research. The benchmarks and writeups live on GitHub.
        </p>
      </div>
      <a
        href="https://github.com/DaRealSun?tab=repositories"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-ghost"
      >
        All repos
        <svg
          class="h-3.5 w-3.5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <path d="M7 17 17 7"></path>
          <path d="M8 7h9v9"></path>
        </svg>
      </a>
    </div>

    <!-- Uniform grid: every project the same size -->
    <div class="mt-14 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        projects.map((p, i) => (
          <article
            class="card card-hover group relative flex h-full flex-col p-7 reveal"
            style={`transition-delay: ${i * 60}ms;`}
          >
            <div
              class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-accent/40 to-transparent opacity-0 transition group-hover:opacity-100"
            />
            <div class="flex items-start justify-between gap-4">
              <h3 class="font-display text-xl font-semibold leading-tight">
                {p.title}
              </h3>
              {p.live && (
                <span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-400/10 px-2.5 py-1 text-xs text-emerald-300">
                  <span class="h-1.5 w-1.5 rounded-full bg-emerald-400" />
                  Live
                </span>
              )}
            </div>

            <p class="mt-3 text-sm leading-relaxed text-text/70">{p.blurb}</p>

            {p.advisor && (
              <p class="mt-3 text-xs text-text/60">
                Faculty advisor:{' '}
                <a
                  href={p.advisor.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-accent hover:underline"
                >
                  {p.advisor.name}
                </a>
              </p>
            )}

            <div class="mt-4 flex flex-wrap gap-2">
              {p.stack.map((s) => (
                <span class="chip">{s}</span>
              ))}
            </div>

            <div class="mt-auto flex flex-wrap items-center gap-4 pt-6 text-sm">
              {p.live && (
                <a
                  href={p.live}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 font-medium text-accent transition hover:gap-3"
                >
                  Live demo
                  <svg
                    class="h-3.5 w-3.5"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path d="M7 17 17 7" />
                    <path d="M8 7h9v9" />
                  </svg>
                </a>
              )}
              {p.repo && (
                <a
                  href={p.repo}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 font-medium text-text/70 transition hover:text-text"
                >
                  Source
                  <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1.1-.7.1-.7.1-.7 1.2.1 1.9 1.3 1.9 1.3 1.1 1.9 2.9 1.4 3.6 1 .1-.8.4-1.4.8-1.7-2.7-.3-5.5-1.3-5.5-6 0-1.3.5-2.4 1.3-3.2-.1-.3-.6-1.6.1-3.3 0 0 1-.3 3.4 1.2a11.7 11.7 0 0 1 6.2 0c2.4-1.5 3.4-1.2 3.4-1.2.7 1.7.2 3 .1 3.3.8.8 1.3 1.9 1.3 3.2 0 4.7-2.8 5.7-5.5 6 .4.4.8 1.1.8 2.2v3.2c0 .3.2.7.8.6A12 12 0 0 0 12 .3" />
                  </svg>
                </a>
              )}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
