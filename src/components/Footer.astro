---
import { site } from '../data/site';
const year = new Date().getFullYear();
---

<footer class="border-t border-border/50 mt-24">
  <div
    class="container-x flex flex-col items-start gap-6 py-10 md:flex-row md:items-center md:justify-between"
  >
    <div>
      <p class="font-display text-lg font-semibold">{site.name}</p>
      <p class="text-sm text-muted">{site.title} · {site.location}</p>
    </div>
    <div class="flex items-center gap-3">
      <a
        href={site.github}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
        class="grid h-10 w-10 place-items-center rounded-full border border-border text-text/70 transition hover:border-text hover:text-text"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"
          ><path
            d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1.1-.7.1-.7.1-.7 1.2.1 1.9 1.3 1.9 1.3 1.1 1.9 2.9 1.4 3.6 1 .1-.8.4-1.4.8-1.7-2.7-.3-5.5-1.3-5.5-6 0-1.3.5-2.4 1.3-3.2-.1-.3-.6-1.6.1-3.3 0 0 1-.3 3.4 1.2a11.7 11.7 0 0 1 6.2 0c2.4-1.5 3.4-1.2 3.4-1.2.7 1.7.2 3 .1 3.3.8.8 1.3 1.9 1.3 3.2 0 4.7-2.8 5.7-5.5 6 .4.4.8 1.1.8 2.2v3.2c0 .3.2.7.8.6A12 12 0 0 0 12 .3"
          ></path></svg
        >
      </a>
      <a
        href={site.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
        class="grid h-10 w-10 place-items-center rounded-full border border-border text-text/70 transition hover:border-text hover:text-text"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"
          ><path
            d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.36V9h3.41v1.56h.05c.47-.9 1.63-1.85 3.36-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43A2.06 2.06 0 1 1 5.35 3.3a2.06 2.06 0 0 1-.01 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"
          ></path></svg
        >
      </a>
      <a
        href={`mailto:${site.email}`}
        aria-label="Email"
        class="grid h-10 w-10 place-items-center rounded-full border border-border text-text/70 transition hover:border-text hover:text-text"
      >
        <svg
          class="h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <rect x="3" y="5" width="18" height="14" rx="2"></rect>
          <path d="m3 7 9 6 9-6"></path>
        </svg>
      </a>
    </div>
  </div>
  <div class="container-x pb-10 text-xs text-muted">
    © {year} {site.name}. Built with Astro + Tailwind.
  </div>
</footer>
